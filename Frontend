"""
This file is to create a streamlit application for front end
"""
import streamlit as st
import pandas as pd
import requests


st.title("Tip Prediction App")

# input data
total_bill = st.number_input("Total Bill", min_value=0)
sex = st.selectbox("Sex", options=["Male", "Female"])
smoker = st.selectbox("Smoker", options=["Yes", "No"])
day = st.selectbox("Day", options=["Thur", "Fri", "Sat","Sun"])
time = st.selectbox("Time", options=["Lunch", "Dinner"])
size = st.number_input("Size", min_value=1)

if st.button("Predict Tip"):
    input_data = {
        "total_bill": total_bill,
        "sex": sex,
        "smoker": smoker,
        "day": day,
        "time": time,
        "size": size
    }
    response = requests.post("http://localhost:5000/predict", json=input_data)

    if response.status_code == 200:
        prediction = response.json().get("prediction")
        st.success(f"Predicted Tip: ${prediction:.2f}")
    else:
        st.error("Error occurred while making prediction.")
